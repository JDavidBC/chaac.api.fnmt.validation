<?xml version="1.0" encoding="utf-8"?>
<!--
  This web.config is used by IIS when hosting the ASP.NET Core application.
  The AspNetCoreModuleV2 (ASP.NET Core Hosting Bundle) must be installed on the server.

  Client certificate requirements are configured in IIS Manager, not here.
  See docs/IIS-Deployment.md for step-by-step instructions.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\Chaac.Api.Fnmt.Validation.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
        <!--
          forwardWindowsAuthToken is not needed for certificate auth, but
          clientCertificateMode must be configured in IIS → SSL Settings.
        -->
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
